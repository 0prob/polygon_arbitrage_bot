# Polygon Arb Bot — .env.example
# Copy this file to .env and edit with your credentials
#
# Config is validated via Zod in src/config/schema.ts. See defaults in src/config/defaults.ts.

# ─── REQUIRED ────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x0123...cdef             # 0x + 64 hex for tx signing (gas/submission only)
EXECUTOR_ADDRESS=0x0123...cdef        # Address of deployed ArbExecutor (pure Huff contract)
ENVIO_API_TOKEN=your_envio_token_here  # Paid or starter plan Envio token for indexer + HyperSync

# ─── RPC CONFIGURATION ───────────────────────────────────────────────────────
EXECUTION_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY  # RPC used for tx submits & gas queries
POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-rpc.com  # Comma-separated reads/indexing endpoints
CHAINSTACK_RPS=250                    # Rate-limiting constraint (RPS) for direct requests
ALCHEMY_API_KEY=YOUR_KEY              # Alchemy API key (for Alchemy SDK features)
# ALCHEMY_BATCH_REQUESTS=true         # Enable/disable Alchemy JSON-RPC batching (default is true)

# Optional: High-performance read providers
# HYPERRPC_URL=https://polygon.hypersync.xyz
# HYPERRPC_API_TOKEN=your_token_here
# HYPER_SYNC_URL=
# HYPERSYNC_MAX_RPM_PER_TOKEN=200      # Pacing limit for direct HyperSync connections
# STATE_RPC_URL=                       # Optional state override provider

# ─── CORE ARBITRAGE BEHAVIOR ─────────────────────────────────────────────────
MIN_PROFIT_WEI=100000000000000000     # Minimum profit in wei (0.1 MATIC default)
SLIPPAGE_BPS=50                       # Slippage tolerance in basis points (0.5% default)
REVERT_RISK_BPS=500                   # Revert risk penalty in basis points (5% default)
FLASH_LOAN_SOURCE=BALANCER            # Flash loan provider: BALANCER | AAVE_V3
FLASH_LOAN_FEE_BPS=0                  # Balancer flash loan fee in BPS (0 on Polygon)
FLASH_LOAN_FEE_BPS_AAVE=5             # Aave V3 flash loan fee in BPS (0.05% default)
MIN_LIQUIDITY_V3_RATE=1000            # Minimum liquidity rate floor for Uniswap V3 pools

# ─── ROUTING & CYCLE FINDING ─────────────────────────────────────────────────
ROUTING_MAX_HOPS=5                    # Max hops for cycle search (5 is recommended)
CYCLE_REFRESH_INTERVAL_MS=1000        # Interval (ms) to check for rate updates
LIQUIDITY_FLOOR_USD=100               # Disregard pools with TVL below this limit
ROUTING_ENUMERATION_MAX_PATHS=5000    # Maximum paths to evaluate in search
ROUTING_CONCURRENCY=75                # Simultaneous cycle simulations
TERNARY_SEARCH_ITERATIONS=12          # Optimization iterations for input sizing
MAX_PRICE_IMPACT_THRESHOLD=0.1        # Maximum price impact allowed (10% default)
GRAPH_FULL_REBUILD_INTERVAL=100       # Complete graph refresh interval (in blocks)
ROUTING_CYCLE_FINDER=dfs              # Cycle finder algorithm: dfs | bellman-ford

# ─── TRANSACTION SUBMISSION ──────────────────────────────────────────────────
SUBMISSION_STRATEGY=hybrid            # public | private | hybrid
RECEIPT_TIMEOUT_MS=30000              # Transaction receipt wait timeout
# PRIVATE_RELAY_URLS=                 # Optional private relay RPCs

# ─── MEMPOOL (Awareness of competitor txs) ──────────────────────────────────
MEMPOOL_ENABLED=true
MEMPOOL_WEBSOCKET_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
MEMPOOL_COALESCE_TTL_MS=100
MEMPOOL_LARGE_SWAP_THRESHOLD_USD=10000

# ─── OBSERVABILITY & DATA ────────────────────────────────────────────────────
LOG_LEVEL=info                        # trace | debug | info | warn | error
# TUI=false                           # Enable Terminal UI (TUI) dashboard (default is false)
DATA_DIR=data                         # Directory where discovery/token data is stored
PERF_JSON_FILE=perf.json              # File to output latency/performance metrics

# ─── INDEXER / HYPERINDEX (Envio + Hasura) ───────────────────────────────────
HASURA_URL=http://localhost:8080/v1/graphql
HASURA_SECRET=testing

# ─── GAS & RISK CONTROLS ─────────────────────────────────────────────────────
# POLYGON_PRIORITY_FEE_FLOOR_GWEI=30
# POLYGON_PRIORITY_FEE_CEILING_GWEI=500
# EIP1559_ENABLED=true
QUARANTINE_BASE_MS=2000
QUARANTINE_MAX_MS=600000
ROI_SAFETY_CAP=10.0
ENVIO_HYPERSYNC_RPM_TARGET=195
ETHERSCAN_API_KEY=                    # Optional Etherscan API key for contract verification
