# Polygon Arb Bot — .env.example (current as of post-audit)
#
# cp .env.example .env && edit
# All config validated by Zod (src/config/schema.ts). See defaults in src/config/defaults.ts
# and loader in src/config/loader.ts .
#
# The entire system is STRICTLY flash-loan-only (no capital paths). See AGENTS.md.

# ─── REQUIRED ────────────────────────────────────────────────────────────────
ENVIO_API_TOKEN=your_envio_token_here
PRIVATE_KEY=0x0123...cdef             # 0x + 64 hex for tx signing (gas only)
EXECUTOR_ADDRESS=0x0123...cdef        # Deployed ArbExecutor (flash loan only contract)

# ─── RPC (at least one good archival for HyperIndex + execution) ─────────────
# EXECUTION_RPC is used for submits/gas; POLYGON_RPC_URLS for reads/indexer.
# Comma sep list ok; bot prefers archival.
EXECUTION_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-rpc.com

# Optional high perf read provider (HyperRPC when token set)
# HYPERRPC_API_TOKEN=
# HYPERRPC_URL=

# ─── HyperIndex / Hasura (local Envio dev or hosted) ─────────────────────────
HASURA_URL=http://localhost:8080/v1/graphql
HASURA_SECRET=testing
# ENVIO_API_TOKEN above is also used for HyperSync in indexer.

# ─── ARBITRAGE TUNING (see src/core/assessment , pipeline) ───────────────────
MIN_PROFIT_WEI=100000000000000000     # 0.1 MATIC default
SLIPPAGE_BPS=50
REVERT_RISK_BPS=500
FLASH_LOAN_SOURCE=BALANCER            # BALANCER or AAVE_V3
# FLASH_LOAN_FEE_BPS=0
# FLASH_LOAN_FEE_BPS_AAVE=5

ROUTING_MAX_HOPS=5
# TERNARY_SEARCH_ITERATIONS=12
# MAX_PRICE_IMPACT_THRESHOLD=0.05

# Submission
SUBMISSION_STRATEGY=hybrid
# FastLane optional
# FASTLANE_ENABLED=false
# FASTLANE_RPC_URL=https://polygon-rpc.fastlane.xyz

# Mempool (for competing tx awareness)
MEMPOOL_ENABLED=true
# MEMPOOL_WEBSOCKET_URL=wss://...

# ─── OBSERVABILITY ───────────────────────────────────────────────────────────
LOG_LEVEL=info
TUI=true                              # or false for headless
DATA_DIR=data

# ─── OPTIONAL / GAS / RISK ───────────────────────────────────────────────────
# Gas oracle tuning (defaults usually fine)
# POLYGON_PRIORITY_FEE_FLOOR_GWEI=30
# etc.

# ROI outlier protection
# ROI_SAFETY_CAP=10.0

# Quarantine
# QUARANTINE_BASE_MS=2000
# QUARANTINE_MAX_MS=600000

# ─── NOTES ───────────────────────────────────────────────────────────────────
# For AI debugging superpowers: see .grok/skills/arb-tx-tools/SKILL.md
#   Direct CLIs: bun .grok/skills/arb-tx-tools/scripts/{simulator,abicoder,log-tailer}.ts ...
#   MCP (if registered in your env): bun run scripts/arb-tx-tools.ts
#
# After edit: bun run typecheck && bun test
# Run: bun run src/cli/main.ts --tui
# Arb-only (external indexer): bun run src/cli/arb_only.ts --tui

# ─────────────────────────────────────────────────────────────────────────────
# 3. CORE ARBITRAGE BEHAVIOR
# ─────────────────────────────────────────────────────────────────────────────

# Minimum profit required before attempting execution (in wei)
MIN_PROFIT_WEI=100000000000000000   # 0.1 MATIC (adjust to your risk tolerance)

# Slippage tolerance in basis points
SLIPPAGE_BPS=50

# Revert risk penalty (higher = more conservative)
REVERT_RISK_BPS=500

# Flash loan provider
FLASH_LOAN_SOURCE=BALANCER          # BALANCER | AAVE_V3
FLASH_LOAN_FEE_BPS=0                # Balancer is 0 on Polygon
FLASH_LOAN_FEE_BPS_AAVE=5

# Max hops for cycle search (5 is good for long-tail; 3-4 is more conservative)
ROUTING_MAX_HOPS=5

# Submission strategy
SUBMISSION_STRATEGY=hybrid          # public | private | hybrid
DRY_RUN_BEFORE_SUBMIT=true

# Mempool monitoring (helps avoid toxic flow / detect competition)
MEMPOOL_ENABLED=true
MEMPOOL_WEBSOCKET_URL=              # wss://... alchemy or similar

# ─────────────────────────────────────────────────────────────────────────────
# 4. OBSERVABILITY & PATHS
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info                      # trace | debug | info | warn | error
TUI=true                            # Set to false for headless / scripting
DATA_DIR=data
PERF_JSON_FILE=perf.json

# ─────────────────────────────────────────────────────────────────────────────
# 5. OPTIONAL / ADVANCED
# ─────────────────────────────────────────────────────────────────────────────

# Gas tuning (only change if you know what you're doing)
# POLYGON_PRIORITY_FEE_FLOOR_GWEI=30
# POLYGON_PRIORITY_FEE_CEILING_GWEI=500
# EIP1559_ENABLED=true

# Execution risk controls
QUARANTINE_BASE_MS=2000
QUARANTINE_MAX_MS=600000
ROI_SAFETY_CAP=10.0

# Receipt polling
RECEIPT_TIMEOUT_MS=30000
# RECEIPT_POLL_MS=500
