# ─── Polygon Arb Bot ── Environment Reference ──────────────────────
#
# Copy to .env and fill in secrets. Required vars must be set for the
# bot to boot — missing any triggers a config validation error.
#
# Config is loaded: built-in defaults → env var overrides → Zod validation
# See src/config/defaults.ts, src/config/loader.ts

# ─── 1. REQUIRED SECRETS ───────────────────────────────────────────

ENVIO_API_TOKEN=                # Envio API token (envio.dev/app)
PRIVATE_KEY=                    # Live-mode signing key (0x + 64 hex chars)
EXECUTOR_ADDRESS=               # Deployed ArbExecutor contract (0x…)
POLYGON_SOLVER_PRIVATE_KEY=     # Private key for solving on Polygon (Cross-chain)
KATANA_SOLVER_PRIVATE_KEY=      # Private key for solving on Katana (Cross-chain)

# ─── 2. INFRASTRUCTURE ─────────────────────────────────────────────

EXECUTION_RPC=                  # Primary RPC for read/watch queries + eth_estimateGas
GAS_ESTIMATION_RPC=             # Dedicated gas estimation RPC (can match EXECUTION_RPC)
POLYGON_RPC_URLS=               # Comma-separated fallback RPC pool (latency rotation)
HYPERRPC_URL=                   # HyperSync JSON-RPC endpoint (default: https://polygon.rpc.hypersync.xyz)
KATANA_RPC_URL=                 # RPC for Katana chain
CROSS_CHAIN_POLYGON_RPC_URL=    # Secondary Polygon RPC for cross-chain sync
CONFIG_JSON_RPC_TIMEOUT_MS=8000 # Request timeout ms
RPC_BATCH_WAIT_MS=16            # Wait time before sending a batch
RPC_BATCH_SIZE=100              # Max requests per batch

# HyperSync
HYPERSYNC_URL=                  # Streaming endpoint (default: https://polygon.hypersync.xyz)
HYPERSYNC_HTTP_REQ_TIMEOUT_MS=60000
HYPERSYNC_MAX_RETRIES=5
HYPERSYNC_BATCH_SIZE=5000
HYPERSYNC_MAX_BLOCKS_PER_REQUEST=1000000
HYPERSYNC_MAX_ADDRESS_FILTER=25000
HYPERSYNC_PROACTIVE_RATE_LIMIT_SLEEP_MS=0
HYPERSYNC_RETRY_BASE_MS=200
HYPERSYNC_RETRY_CEILING_MS=5000
HYPERSYNC_RETRY_BACKOFF_MS=1000
HYPERSYNC_MAX_FILTERS_PER_REQUEST=50
HYPERSYNC_STREAM_CONCURRENCY=20
HYPERSYNC_STREAM_BATCH_SIZE=1000

# Hasura (HyperIndex)
HASURA_URL=http://localhost:8080/v1/graphql
HASURA_SECRET=testing

# ─── 3. BOT TUNING ─────────────────────────────────────────────────

# Gas
GAS_POLL_INTERVAL_MS=2000       # Fee oracle poll interval ms
GAS_BUFFER_BPS=105              # Gas estimate buffer (bps)
GAS_MULTIPLIER=110              # Gas multiplier (%)
POLYGON_PRIORITY_FEE_FLOOR_GWEI=30
POLYGON_PRIORITY_FEE_CEILING_GWEI=500
POLYGON_MAX_BID_MULTIPLIER=5
GAS_CACHE_TTL_MS=120000
GAS_CACHE_SIZE=2048
GAS_DEFAULT_BUFFER_BPS=105
EIP1559_ENABLED=true            # Enable EIP-1559 dynamic fee calculation
GAS_EMA_ALPHA=0.3               # EMA smoothing factor for base fee prediction (0-1)
GAS_BASE_FEE_BUFFER_MULTIPLIER=1.1 # Multiplier on predicted base fee
GAS_MAX_PRIORITY_FEE_PERCENTILE=75 # Percentile for dynamic priority fee selection
GAS_HISTORY_SIZE=20             # Number of historical data points for fee prediction

# Routing
ROUTING_MAX_HOPS=4              # Max hops in cycle search
MAX_TOTAL_PATHS=50000           # Max candidate paths in memory
MAX_PATHS_TO_OPTIMIZE=40        # Top paths optimized per pass
CYCLE_REFRESH_INTERVAL_MS=1000  # Cycle cache rebuild interval
LIQUIDITY_FLOOR_USD=5000        # Min pool liquidity (USD)
WORKER_COUNT=                   # Simulation worker threads (default: CPU-1)
EVAL_WORKER_THRESHOLD=20        # Offload threshold for worker IPC
ROUTING_ENUMERATION_MAX_PATHS=5000
ROUTING_ENUMERATION_MAX_4HOP_PATHS=2000
TERNARY_SEARCH_ITERATIONS=15      # Ternary search iterations per cycle (5-50)
MAX_PRICE_IMPACT_THRESHOLD=0.15   # Max price impact before pruning a route (0.01-0.5)
GRAPH_FULL_REBUILD_INTERVAL=100   # Cycles between full graph rebuilds

# Discovery
DISCOVERY_REFRESH_INTERVAL_MS=300000
DISCOVERY_CONCURRENCY=4


# Watcher
WATCHER_IDLE_SLEEP_MS=1000
WATCHER_ENRICHMENT_BACKFILL_LOOKBACK=1000
WATCHER_ENRICHMENT_MAX_POOLS=500

# ─── 4. EXECUTION & RISK ───────────────────────────────────────────

MIN_PROFIT_WEI=1000000000000000 # Min profit in MATIC wei (default: 0.001 MATIC)
SLIPPAGE_BPS=50                 # Slippage tolerance (bps)
REVERT_RISK_BPS=500             # Revert risk penalty (bps)
FLASH_LOAN_FEE_BPS=0            # Balancer flash-loan fee (bps)
FLASH_LOAN_FEE_BPS_AAVE=5       # Aave V3 flash-loan fee (bps)
FLASH_LOAN_SOURCE=BALANCER      # Flash loan provider: BALANCER | AAVE_V3
PRIVATE_RELAY_URLS=             # Comma-separated private relay URLs
SUBMISSION_STRATEGY=hybrid      # public | private | hybrid
DRY_RUN_BEFORE_SUBMIT=true      # Dry-run before submit
RECEIPT_TIMEOUT_MS=30000        # Timeout for waiting for transaction receipt
MAX_CONCURRENT_EXECUTIONS=2     # Limit concurrent execution attempts (2 for moderate parallelism)
QUARANTINE_BASE_MS=2000         # Initial quarantine backoff for failed routes (ms)
QUARANTINE_MAX_MS=600000        # Max quarantine backoff (ms, default 10 min)
CHAIN_ID=137                    # Polygon Mainnet Chain ID

# ─── 5. FEATURES ───────────────────────────────────────────────────

# FastLane (Polygon private mempool)
FASTLANE_ENABLED=false          # Enable Polygon FastLane bundle submission
FASTLANE_RPC_URL=https://polygon-rpc.fastlane.xyz
FASTLANE_BLOCK_WINDOW=50        # Max blocks to attempt inclusion
FASTLANE_TIMESTAMP_WINDOW_S=60  # Max timestamp window for conditional tx

# Mempool
MEMPOOL_ENABLED=true
MEMPOOL_WEBSOCKET_URL=          # WebSocket for pending tx subscription (optional)
MEMPOOL_COALESCE_TTL_MS=100     # Time to wait for batching mempool events
MEMPOOL_LARGE_SWAP_THRESHOLD_USD=10000

# Predictive Cache
PREDICTIVE_CACHE_ENABLED=false
PREDICTIVE_CACHE_MAX_PATHS=500
PREDICTIVE_CACHE_PRECOMPUTE_COUNT=50
PREDICTIVE_CACHE_REFRESH_INTERVAL_MS=100

# Cross-Chain (Polygon ↔ Katana)
CROSS_CHAIN_ARB_ENABLED=false
ESCROW_TOKEN=                   # Escrow token address
ESCROW_AMOUNT=10                # Amount to escrow
MIN_PROFIT_BPS=20               # Min profit in basis points
MAX_SWAP_HOPS=3                 # Max hops for cross-chain swaps
ORIGIN_SETTLER_ADDRESS=         # Settler contract address on origin chain
KATANA_EXECUTOR_ADDRESS=        # Executor contract address on Katana
KATANA_EXECUTOR_ENABLED=true    # Enable Katana executor

# ─── 6. OBSERVABILITY ──────────────────────────────────────────────

LOG_LEVEL=info                  # trace|debug|info|warn|error|fatal|silent
TUI=false                       # Enable TUI mode
DATA_DIR=data                   # Directory for persistent data
PERF_JSON_FILE=perf.json        # File for performance metrics
