# Polygon Arb Bot — Clean .env Template
#
# Copy this file to .env and fill in the required values.
# The bot uses Zod validation — missing required fields will cause a clear startup error.
#
# Config precedence: defaults → environment variables → validation
# See: src/config/defaults.ts, src/config/schema.ts, src/config/loader.ts

# ─────────────────────────────────────────────────────────────────────────────
# 1. REQUIRED (the bot will not start without these)
# ─────────────────────────────────────────────────────────────────────────────

ENVIO_API_TOKEN=                    # Get from https://envio.dev/app
PRIVATE_KEY=0x...                   # 0x + 64 hex chars (signing key)
EXECUTOR_ADDRESS=0x...              # Deployed ArbExecutor on Polygon

# ─────────────────────────────────────────────────────────────────────────────
# 2. RPC & INFRASTRUCTURE
# ─────────────────────────────────────────────────────────────────────────────

# Primary execution + gas estimation RPC (Alchemy, QuickNode, etc. recommended)
EXECUTION_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Comma-separated list of RPCs used by HyperIndex and general reads.
# The bot will probe and prefer the best archival endpoints.
POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-rpc.com

# Optional: High-performance HyperRPC (read-only) from Envio
# When set, many read operations are routed through it automatically.
HYPERRPC_API_TOKEN=

# HyperIndex (Envio) local instance
HASURA_URL=http://localhost:8080/v1/graphql
HASURA_SECRET=testing

# ─────────────────────────────────────────────────────────────────────────────
# 3. CORE ARBITRAGE BEHAVIOR
# ─────────────────────────────────────────────────────────────────────────────

# Minimum profit required before attempting execution (in wei)
MIN_PROFIT_WEI=100000000000000000   # 0.1 MATIC (adjust to your risk tolerance)

# Slippage tolerance in basis points
SLIPPAGE_BPS=50

# Revert risk penalty (higher = more conservative)
REVERT_RISK_BPS=500

# Flash loan provider
FLASH_LOAN_SOURCE=BALANCER          # BALANCER | AAVE_V3
FLASH_LOAN_FEE_BPS=0                # Balancer is 0 on Polygon
FLASH_LOAN_FEE_BPS_AAVE=5

# Max hops for cycle search (5 is good for long-tail; 3-4 is more conservative)
ROUTING_MAX_HOPS=5

# Submission strategy
SUBMISSION_STRATEGY=hybrid          # public | private | hybrid
DRY_RUN_BEFORE_SUBMIT=true

# FastLane (Polygon private mempool) - optional but recommended when available
FASTLANE_ENABLED=false
FASTLANE_RPC_URL=https://polygon-rpc.fastlane.xyz

# Mempool monitoring (helps avoid toxic flow / detect competition)
MEMPOOL_ENABLED=true
MEMPOOL_WEBSOCKET_URL=              # wss://... alchemy or similar

# ─────────────────────────────────────────────────────────────────────────────
# 4. OBSERVABILITY & PATHS
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info                      # trace | debug | info | warn | error
TUI=true                            # Set to false for headless / scripting
DATA_DIR=data
PERF_JSON_FILE=perf.json

# ─────────────────────────────────────────────────────────────────────────────
# 5. OPTIONAL / ADVANCED
# ─────────────────────────────────────────────────────────────────────────────

# Gas tuning (only change if you know what you're doing)
# POLYGON_PRIORITY_FEE_FLOOR_GWEI=30
# POLYGON_PRIORITY_FEE_CEILING_GWEI=500
# EIP1559_ENABLED=true

# Execution risk controls
QUARANTINE_BASE_MS=2000
QUARANTINE_MAX_MS=600000
ROI_SAFETY_CAP=10.0

# Receipt polling
RECEIPT_TIMEOUT_MS=30000
# RECEIPT_POLL_MS=500

# ─────────────────────────────────────────────────────────────────────────────
# 6. HYPERSYNC / ENVIO MULTI-KEY RATE LIMIT STRATEGY (FREE TIER)
# ─────────────────────────────────────────────────────────────────────────────
# Free-tier ENVIO_API_TOKENs are heavily rate-limited (~60 req/min on HyperSync).
# When one key hits the wall, Envio's internal client can stall for long periods.
#
# Solution: keep multiple free keys and let the system rotate them.
#
# Recommended:
#   - Put all your free keys in hyperindex/.env (even as commented lines — the loader will find them)
#   - Or set ENVIO_API_TOKENS=token1,token2,token3 (comma-separated) in this file
#
# The HyperIndex launcher + the bot's direct HyperSyncService will:
#   - Automatically pick a different key on each hyperindex restart (triggered by stalls)
#   - Use local pacing (maxRpmPerToken) so the bot itself doesn't hammer keys
#   - Spread load across keys for the direct hypersync calls (monitoring, traces, etc.)
#
# Example (in this .env or hyperindex/.env):
#   ENVIO_API_TOKENS=492d2797-...,4c5649fd-...,b129c707-...
ENVIO_API_TOKENS=492d2797-d1f2-4154-8a57-45976d2cbab1,fe34f617-7101-4ab9-8025-d7b1926748bf,b129c707-61fa-49a4-ab61-f6f231db7334,4c5649fd-98fc-41fc-a5ba-69b2035e6f5c,eb7e4200-3b09-4fe5-a36c-a60b4c0f68db
# Or just list them (commented is fine) in hyperindex/.env:
#   #ENVIO_API_TOKEN=fe34f617-...
#   #ENVIO_API_TOKEN=b129c707-...
#    ENVIO_API_TOKEN=4c5649fd-...   # active one today
#
# You can also set a conservative client-side cap for the bot's direct usage:
#   HYPERSYNC_MAX_RPM_PER_TOKEN=45
HYPERSYNC_MAX_RPM_PER_TOKEN=45
#
# This approach usually lets you sustain more total work than a single key that
# repeatedly hits hard limits and enters long backoff windows.
