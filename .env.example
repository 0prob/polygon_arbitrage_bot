# ─── Polygon Arbitrage Bot ── Environment Reference ──────────────
#
# Config is loaded in this priority order (lowest wins):
#   1. Built-in defaults (src/config/defaults.ts)
#   2. Environment variables (listed below)
#   3. data/perf.json (runtime tuning)
#
# Copy to .env, fill in secrets. Required vars must be set for the bot to boot.
#
# ─── REQUIRED ────────────────────────────────────────────────────
# Missing any of these → config validation error on startup.

# Envio API token for HyperSync streaming + HyperRPC queries.
ENVIO_API_TOKEN=

# Primary RPC for read/watch queries and eth_estimateGas simulations.
EXECUTION_RPC=

# Dedicated RPC for gas estimation (eth_estimateGas). Can match EXECUTION_RPC.
GAS_ESTIMATION_RPC=

# Deployed ArbExecutor contract address (0x-prefixed).
EXECUTOR_ADDRESS=

# Live-mode signing key (0x + 64 hex chars). NEVER commit a funded key.
PRIVATE_KEY=

# ─── RPC ─────────────────────────────────────────────────────────
# Comma-separated fallback RPC pool (latency-based rotation).
POLYGON_RPC_URLS=
# (alias for a single-entry POLYGON_RPC_URLS)
POLYGON_RPC=

# HyperSync JSON-RPC endpoint. Default: https://polygon.rpc.hypersync.xyz
HYPERRPC_URL=

# JSON-RPC request timeout in ms. Default: 8000
CONFIG_JSON_RPC_TIMEOUT_MS=

# ─── HyperSync ───────────────────────────────────────────────────
# Polygon HyperSync streaming endpoint. Default: https://polygon.hypersync.xyz
HYPERSYNC_URL=
# HTTP timeout. Default: 60000
HYPERSYNC_HTTP_REQ_TIMEOUT_MS=
# Retry count. Default: 5
HYPERSYNC_MAX_RETRIES=
# Logs fetched per batch. Default: 5000
HYPERSYNC_BATCH_SIZE=
# Max blocks per request. Default: 1000000
HYPERSYNC_MAX_BLOCKS_PER_REQUEST=
# Max address filter size. Default: 25000
HYPERSYNC_MAX_ADDRESS_FILTER=
# Rate-limit sleep (ms). Default: 0
HYPERSYNC_PROACTIVE_RATE_LIMIT_SLEEP_MS=

# ─── Gas ─────────────────────────────────────────────────────────
# Background fee oracle poll interval (ms). Default: 2000
GAS_POLL_INTERVAL_MS=
# Gas estimate buffer in bps. Default: 105
GAS_BUFFER_BPS=
# Gas multiplier (%). Default: 110
GAS_MULTIPLIER=
# Priority fee floor (gwei). Default: 30
POLYGON_PRIORITY_FEE_FLOOR_GWEI=
# Priority fee ceiling (gwei). Default: 500
POLYGON_PRIORITY_FEE_CEILING_GWEI=
# Max bid multiplier. Default: 5
POLYGON_MAX_BID_MULTIPLIER=

# ─── Routing ─────────────────────────────────────────────────────
# Max hops in cycle search. Default: 4
ROUTING_MAX_HOPS=
# Max candidate paths kept in memory. Default: 20000
MAX_TOTAL_PATHS=
# Top candidates optimized per pass. Default: 15
MAX_PATHS_TO_OPTIMIZE=
# Cycle cache rebuild interval (ms). Default: 120000
CYCLE_REFRESH_INTERVAL_MS=
# Min pool liquidity (USD). Default: 5000
LIQUIDITY_FLOOR_USD=
# Simulation worker threads. Default: CPU cores - 1
WORKER_COUNT=
# Offload threshold for worker IPC. Default: 20
EVAL_WORKER_THRESHOLD=

# ─── Execution ───────────────────────────────────────────────────
# Min profit in MATIC wei. Default: 1000000000000000 (0.001 MATIC)
MIN_PROFIT_WEI=
# Slippage tolerance (bps). Default: 50
SLIPPAGE_BPS=
# Revert risk penalty (bps). Default: 500
REVERT_RISK_BPS=
# Balancer flash-loan fee (bps). Default: 0
FLASH_LOAN_FEE_BPS=
# Comma-separated private relay URLs for tx submission.
PRIVATE_RELAY_URLS=
# Dry-run before submit. Default: true
DRY_RUN_BEFORE_SUBMIT=

# ─── Predictive Cache ────────────────────────────────────────────
PREDICTIVE_CACHE_ENABLED=false
PREDICTIVE_CACHE_MAX_PATHS=500

# ─── Mempool ─────────────────────────────────────────────────────
MEMPOOL_ENABLED=true
# WebSocket URL for pending tx subscription (optional).
MEMPOOL_WEBSOCKET_URL=
# Large-swap threshold (USD). Default: 10000
MEMPOOL_LARGE_SWAP_THRESHOLD_USD=

# ─── Observability ───────────────────────────────────────────────
# Log level: trace|debug|info|warn|error|fatal. Default: info
LOG_LEVEL=info
# Enable TUI mode. Default: false
TUI=false
