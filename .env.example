# Polygon arb bot environment variables
# Copy to .env and fill in your values. Validated via src/config/schema.ts (defaults in src/config/defaults.ts).

# ─── Required ────────────────────────────────────────────────────────────────

# Wallet private key for signing transactions (0x + 64 hex chars)
PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Deployed ArbExecutor contract address
EXECUTOR_ADDRESS=0x0123456789012345678901234567890123456789

# RPC endpoint for tx submission, receipts, and gas queries
EXECUTION_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Envio API token for HyperIndex / HyperSync (strongly recommended)
# Used by the bot HyperSync client and the HyperIndex subprocess — NOT HyperRPC.
ENVIO_API_TOKEN=your_envio_token_here

# HyperSync endpoint for bot-side reads (optional; shares ENVIO_API_TOKEN quota with indexer)
# HYPER_SYNC_URL=https://polygon.hypersync.xyz

# ─── RPC ─────────────────────────────────────────────────────────────────────

# Comma-separated archival RPC URLs for pool discovery and state reads
POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-rpc.com

# Client-side request rate limit (RPS) for direct RPC calls
CHAINSTACK_RPS=250

# Alchemy API key (enables Alchemy SDK batching on Alchemy endpoints)
ALCHEMY_API_KEY=YOUR_KEY

# HyperRPC URL for high-performance read methods (optional)
# HYPERRPC_URL=https://polygon.hypersync.xyz

# HyperRPC bearer token (optional, pair with HYPERRPC_URL — read RPC only, not HyperSync)
# HYPERRPC_API_TOKEN=your_hyperrpc_token_here

# ─── Indexer (HyperIndex + Hasura) ───────────────────────────────────────────

# Hasura GraphQL endpoint for the local Envio indexer
HASURA_URL=http://localhost:8080/v1/graphql

# Hasura admin secret (must match hyperindex config)
HASURA_SECRET=testing

# HyperSync RPM target passed to the indexer subprocess (paid starter ~200, free tier ~100-150)
HYPERSYNC_RPM_TARGET=200

# Override indexer start block for faster live-tail sync (optional)
# POLYGON_START_BLOCK=5024576

# ─── Profit & execution ──────────────────────────────────────────────────────

# Minimum net profit in wei after flash-loan fees
MIN_PROFIT_WEI=100000000000000000

# Slippage tolerance in basis points
SLIPPAGE_BPS=50

# Revert-risk penalty in basis points
REVERT_RISK_BPS=500

# Flash loan provider: BALANCER | AAVE_V3
FLASH_LOAN_SOURCE=BALANCER

# Balancer flash loan fee in basis points (0 on Polygon)
FLASH_LOAN_FEE_BPS=0

# Aave V3 flash loan fee in basis points
FLASH_LOAN_FEE_BPS_AAVE=5

# Minimum Uniswap V3 liquidity rate floor
MIN_LIQUIDITY_V3_RATE=100000000000000000

# ─── Routing ─────────────────────────────────────────────────────────────────

# Maximum hops in arbitrage cycle search
ROUTING_MAX_HOPS=5

# Interval (ms) between rate refresh passes
CYCLE_REFRESH_INTERVAL_MS=1000

# Ignore pools below this USD liquidity
LIQUIDITY_FLOOR_USD=100

# Maximum cycle paths to enumerate per refresh
ROUTING_ENUMERATION_MAX_PATHS=5000

# Concurrent cycle simulations
ROUTING_CONCURRENCY=75

# Ternary search iterations for input sizing
TERNARY_SEARCH_ITERATIONS=12

# Maximum allowed price impact (0.1 = 10%)
MAX_PRICE_IMPACT_THRESHOLD=0.1

# Full graph rebuild interval in blocks
GRAPH_FULL_REBUILD_INTERVAL=100

# Cycle finder algorithm: dfs | bellman-ford
ROUTING_CYCLE_FINDER=dfs

# Max price impact (bps) for V3/V4 hops without loaded tick data (default 30 = 0.30%)
V3_SHALLOW_MAX_IMPACT_BPS=30

# On-demand TickLens tick loading for cycle V3/V4 pools (Polygon TickLens: 0xbfd8137f7d1516D3ea5cA83523914859ec47F573)
# Boolean env vars: use true/false or 1/0 (see loader boolean coercion)
TICK_FETCH_ENABLED=true
TICK_WORD_RANGE=3
TICK_REFRESH_ON_MOVE=true

# ─── State sync ──────────────────────────────────────────────────────────────

# Refresh cycle-pool state immediately on each new block head (instead of waiting for LF tick)
SYNC_HEAD_DRIVEN_REFRESH=true

# Max V3/V4 pools to refresh per newHead event
SYNC_HEAD_REFRESH_MAX_POOLS=50

# ─── Oracle-backed profit valuation ───────────────────────────────────────────

# Chainlink (primary) + Pyth Hermes (fallback) for token/MATIC rates; pool-graph cross-check
ORACLE_ENABLED=true

# Pyth Hermes REST base URL (fallback when Chainlink feed unavailable)
ORACLE_PYTH_HERMES_URL=https://hermes.pyth.network

# Pause token if oracle vs pool-graph rate diverges beyond this (basis points)
ORACLE_MAX_DIVERGENCE_BPS=500

# ─── MEV (FastLane Atlas) ────────────────────────────────────────────────────

# Enable FastLane bundle submission for backrun opportunities (requires solver contract)
MEV_ENABLED=false

# FastLane relay HTTP endpoint (pfl_addSearcherBundle)
MEV_FASTLANE_RELAY_URL=https://polygon-rpc.fastlane.xyz

# Fall back to normal public tx when FastLane rejects or is unavailable
MEV_PUBLIC_BACKRUN_FALLBACK=true

# Advanced strategies (scaffold only; default off)
MEV_JIT_ENABLED=false
MEV_SANDWICH_ENABLED=false

# Max bid as fraction of expected profit (basis points)
MEV_MAX_BID_BPS=500

# ─── Opportunity ranking ─────────────────────────────────────────────────────

# Candidate sort mode before dry-run: statistical | ml | off
RANKING_MODE=statistical

# Path to offline-trained JSON model when RANKING_MODE=ml
RANKING_MODEL_PATH=data/ranking-model.json

# ─── Submission & mempool ────────────────────────────────────────────────────

# Tx submission mode: public | private | hybrid
SUBMISSION_STRATEGY=hybrid

# Receipt wait timeout in milliseconds
RECEIPT_TIMEOUT_MS=30000

# Comma-separated private relay RPC URLs (required for private/hybrid)
# PRIVATE_RELAY_URLS=

# Enable mempool monitoring for competitor tx awareness
MEMPOOL_ENABLED=true

# WebSocket URL for pending tx subscription (required when MEMPOOL_ENABLED=true)
MEMPOOL_WEBSOCKET_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Mempool event coalesce window in milliseconds
MEMPOOL_COALESCE_TTL_MS=100

# Large swap threshold in USD for mempool prioritization
MEMPOOL_LARGE_SWAP_THRESHOLD_USD=10000

# ─── Gas & risk ──────────────────────────────────────────────────────────────

# Gas oracle poll interval in milliseconds
GAS_POLL_INTERVAL_MS=2000

# Priority fee floor in gwei
POLYGON_PRIORITY_FEE_FLOOR_GWEI=30

# Priority fee ceiling in gwei
POLYGON_PRIORITY_FEE_CEILING_GWEI=500

# Base quarantine duration after failed route in milliseconds
QUARANTINE_BASE_MS=2000

# Maximum quarantine duration in milliseconds
QUARANTINE_MAX_MS=600000

# ROI safety cap multiplier for profit sanity checks
ROI_SAFETY_CAP=10.0

# ─── Observability ───────────────────────────────────────────────────────────

# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Enable terminal UI dashboard (true | false)
TUI=false

# Runtime data directory
DATA_DIR=data

# Performance metrics JSON output file
PERF_JSON_FILE=perf.json
