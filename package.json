{
  "name": "polygon-hypersync-discovery",
  "version": "2.0.0",
  "type": "module",
  "main": "runner.ts",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.9.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env --import=tsx runner.ts --loop --live",
    "start:tui": "node --env-file-if-exists=.env --import=tsx runner.ts --loop --live --tui",
    "tune:performance": "node --import=tsx scripts/tune_performance.ts",
    "test": "node --import=tsx scripts/run_ts_test.mjs scripts/run_all_tests.ts",
    "test:e2e": "node --import=tsx scripts/run_ts_test.mjs scripts/test_engine_e2e.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "^1.3.0",
    "ink": "^7.0.2",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "tsx": "^4.21.0",
    "viem": "^2.48.11"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
