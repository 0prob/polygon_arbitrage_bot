{
  "name": "polygon-arb-bot",
  "version": "3.0.0",
  "type": "module",
  "main": "src/cli/main.ts",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "start": "bun --env-file=.env run src/cli/main.ts",
    "start:tui": "bun --env-file=.env run src/cli/main.ts --tui",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun --bun run vitest run",
    "test:watch": "bun --bun run vitest",
    "bench": "bunx vitest bench --run",
    "lint": "bunx eslint src/",
    "lint:fix": "bunx eslint src/ --fix",
    "fmt": "bunx prettier --check src/",
    "fmt:fix": "bunx prettier --write src/",
    "hi:compile": "cd hyperindex && npx tsc --outDir src/handlers_mjs --skipLibCheck --moduleResolution bundler 2>/dev/null; true",
    "hi:start": "cd hyperindex && bunx envio start",
    "hi:codegen": "cd hyperindex && bunx envio codegen"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "^1.3.0",
    "pino": "^10.3.1",
    "viem": "^2.49.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "bun": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
