{
  "name": "polygon-arb-bot",
  "version": "3.1.0",
  "private": true,
  "type": "module",
  "main": "src/cli/main.ts",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "hyperindex"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "start": "bun --env-file=.env run src/cli/main.ts",
    "tui": "bun --env-file=.env run src/cli/main.ts --tui",
    "arb": "bun --env-file=.env run src/cli/arb_only.ts",
    "arbt": "bun --env-file=.env run src/cli/arb_only.ts --tui",
    "dev": "bun --env-file=.env --env-file=hyperindex/.env scripts/dev-hyperindex.ts",
    "fix": "bunx eslint src/ --fix && bunx prettier --write .",
    "rs": "bun scripts/resolve-selectors.ts",
    "dfail": "bun scripts/decode-failing.ts",
    "gentok": "bun run --cwd hyperindex generate-tokens",
    "test": "npx vitest run --coverage",
    "devr": "bun run --cwd hyperindex dev:reset"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "1.4.0",
    "alchemy-sdk": "3.6.5",
    "envio": "3.1.2",
    "pino": "10.3.1",
    "viem": "2.52.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@nomicfoundation/solidity-language-server": "0.8.25",
    "@taplo/cli": "0.7.0",
    "@types/node": "25.9.2",
    "@vitest/coverage-istanbul": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "bash-language-server": "5.6.0",
    "bun-types": "1.3.14",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "fast-check": "4.8.0",
    "graphql-language-service-cli": "3.5.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "typescript-language-server": "5.3.0",
    "vitest": "4.1.8",
    "vscode-langservers-extracted": "4.10.0",
    "yaml-language-server": "1.23.0"
  }
}