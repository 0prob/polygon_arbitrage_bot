{
  "name": "polygon-arb-bot",
  "version": "3.0.0",
  "type": "module",
  "main": "src/cli/main.ts",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env --import=tsx src/cli/main.ts",
    "start:tui": "node --env-file-if-exists=.env --import=tsx src/cli/main.ts --tui",
    "typecheck": "tsc --noEmit -p tsconfig.new.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "fmt": "prettier --check src/",
    "fmt:fix": "prettier --write src/",
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "^1.3.0",
    "pino": "^10.3.1",
    "tsx": "^4.21.0",
    "viem": "^2.48.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
