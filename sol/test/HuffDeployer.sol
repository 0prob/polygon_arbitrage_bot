pragma solidity ^0.8.34;

library HuffDeployer {
    bytes constant CREATION_BYTECODE = hex"";
    
    function deploy(
        address owner_,
        address balancerVault_,
        address uniswapV3Factory_,
        address sushiV3Factory_,
        address quickswapV3Factory_,
        address kyberElasticFactory_,
        address aavePool_,
        address poolManager_
    ) external returns (address) {
        bytes memory bytecode = abi.encodePacked(
            CREATION_BYTECODE,
            abi.encode(
                owner_,
                balancerVault_,
                uniswapV3Factory_,
                sushiV3Factory_,
                quickswapV3Factory_,
                kyberElasticFactory_,
                aavePool_,
                poolManager_
            )
        );
        address addr;
        assembly {
            addr := create(0, add(bytecode, 0x20), mload(bytecode))
        }
        require(addr != address(0), "Huff deployment failed");
        return addr;
    }
}
