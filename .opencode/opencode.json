{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ".opencode/plugins/graphify.js"
  ],
  "mcp": {
    "arb-tx-tools": {
      "type": "local",
      "command": ["bun", "run", "scripts/arb-tx-tools.ts"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "postgresql://postgres:testing@localhost:5433/envio-dev"],
      "enabled": true
    },
    "envio_docs": {
      "type": "remote",
      "url": "https://docs.envio.dev/mcp",
      "enabled": true
    }
  }
}
