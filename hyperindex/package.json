{
  "name": "arb-bot-ingestion",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "envio codegen",
    "dev": "envio dev",
    "run": "envio run",
    "bench": "envio start --bench",
    "bench-summary": "envio benchmark-summary",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bun": "bun test --pass-with-no-tests",
    "generate-tokens": "bun scripts/generate-polygon-tokens.ts",
    "generate-tokens:auto": "bun scripts/update-token-registry.ts",
    "clear-hasura": "bun scripts/clear-hasura-metadata.ts",
    "dev:reset": "bun run clear-hasura || echo '⚠️  clear-hasura failed (missing secret or Hasura not ready) — continuing with full reset anyway' && bunx envio dev -r"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "1.4.0",
    "envio": "3.2.0",
    "viem": "2.52.2"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
